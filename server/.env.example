# Database
DATABASE_URL=postgresql://user:password@localhost:5432/matcha
# SSL mode for PostgreSQL: disable | require | verify-full
DATABASE_SSL=disable

# Gemini API key
LIVE_API=your-gemini-api-key

# Models
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_ANALYSIS_MODEL=gemini-3-flash-preview
GEMINI_VOICE=Kore
GEMINI_HOURLY_LIMIT=50
GEMINI_DAILY_LIMIT=50

# Server
PORT=8000

# App base URL used for OAuth callback redirects
APP_BASE_URL=http://localhost:5173

# OSHA ITA (Injury Tracking Application) electronic 300A filing.
# Optional — defaults to the production API base when unset.
# Set to the sandbox to test filing end-to-end without a real submission
# (sandbox data is purged periodically and does NOT satisfy a filing obligation):
#   OSHA_ITA_API_URL=https://preview.osha.gov/oshaApi/v1
# Per-company ITA API tokens are supplied by each employer in-app (encrypted at
# rest); there is no platform-level OSHA credential.
# OSHA_ITA_API_URL=https://www.osha.gov/oshaApi/v1
