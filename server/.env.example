# Database
DATABASE_URL=postgresql://user:password@localhost:5432/matcha
# SSL mode for PostgreSQL: disable | require | verify-full
DATABASE_SSL=disable

# Gemini API key
LIVE_API=your-gemini-api-key

# Models
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_ANALYSIS_MODEL=gemini-3.5-flash
GEMINI_VOICE=Kore
GEMINI_HOURLY_LIMIT=50
GEMINI_DAILY_LIMIT=50

# Server
PORT=8000

# App base URL used for OAuth callback redirects
APP_BASE_URL=http://localhost:5173
